<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:autofillHints=""
    android:background="@drawable/bg_gradient"
    android:padding="16dp"
    tools:context=".ui.control.InsertarUsuarioActivity">

    <!-- Título de la actividad -->
    <TextView
        android:id="@+id/tvTituloInsertar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Insertar Usuario"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/colorDefault"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"
        tools:ignore="HardcodedText" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFormulario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloInsertar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="#FFFFFF">

    <!-- Layout interno de la Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">



    <!-- Campo de Nombre Completo -->
    <EditText
        android:id="@+id/etNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autofillHints=""
        android:hint="@string/nombre_completo"
        android:inputType="textPersonName"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"

        />

    <!-- Campo de Teléfono -->
    <EditText
        android:id="@+id/etTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autofillHints=""
        android:hint="@string/tel_fono"
        android:inputType="phone"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"

        />

    <!-- Campo de Tipo de Usuario -->
        <Spinner
            android:id="@+id/spinnerTipoUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp" />

    <!-- Campo de Nombre de Empresa o Autónomo -->
    <EditText
        android:id="@+id/etNombreEmpresa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autofillHints=""
        android:hint="@string/nombre_empresa_o_aut_nomo"
        android:inputType="text"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"
         />

    <!-- Campo de Fecha de Alta -->
    <TextView
        android:id="@+id/tvFechaAlta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fecha de Alta: Hoy"
        android:textSize="16sp"
        android:textColor="#000000"
        android:background="@drawable/bg_field"
        android:padding="12dp"
        android:layout_marginBottom="8dp"

        />

    <!-- Estado (predeterminado a 'Activo') -->
    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/estado_activo"
        android:textSize="16sp"
        android:textColor="#000000"
        android:background="@drawable/bg_field"
        android:padding="12dp"/>
    </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!-- Botón Guardar -->
    <Button
        android:id="@+id/btnGuardar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorButton"
        android:text="@string/guardar"
        android:textColor="#212121"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCancelar"
        android:layout_marginEnd="8dp"

         />

    <!-- Botón Cancelar -->
    <Button
        android:id="@+id/btnCancelar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorButton"
        android:text="@string/cancelar"
        android:textColor="#212121"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnGuardar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
